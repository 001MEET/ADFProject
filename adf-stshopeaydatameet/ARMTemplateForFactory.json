		"ls_Blobstorage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_Blobstorage'"
		},
		"ls_SQLdatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_SQLdatabase'"
		},
		"ls_SQLdatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "dbstshopeaydatameet.database.windows.net"
		},
		"ls_SQLdatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db-stshopeaymeet"
