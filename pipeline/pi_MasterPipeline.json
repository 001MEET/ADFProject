{
	"name": "pi_MasterPipeline",
	"properties": {
		"activities": [
			{
				"name": "LoadDimantion",
				"description": "This Pipeline is for to load the dimantion",
				"type": "ExecutePipeline",
				"dependsOn": [],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "PI_CopyDimension",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true
				}
			},
			{
				"name": "Load_CleansedOrders",
				"description": "This pipeline for to load the order facts table",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "LoadDimantion",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "Pi_LoadOrders",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true
				}
			},
			{
				"name": "LoadtheEnrichedData",
				"description": "to insert the pending blank data in sql",
				"type": "ExecuteDataFlow",
				"dependsOn": [
					{
						"activity": "Load_CleansedOrders",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.00:30:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataflow": {
						"referenceName": "DF_Enrichorders",
						"type": "DataFlowReference"
					},
					"compute": {
						"coreCount": 8,
						"computeType": "General"
					},
					"traceLevel": "Fine"
				}
			},
			{
				"name": "Notified OfSucces",
				"description": "Notified Of Succes",
				"type": "WebHook",
				"dependsOn": [
					{
						"activity": "LoadtheEnrichedData",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"url": " https://webhook.site/f802a921-00aa-4877-ac5a-ae7bd93378b0",
					"method": "POST",
					"body": {
						"value": "{\n    \"pipeline\": \"@{pipeline().pipeline}\",\n    \"Status\":\"Success\",\n    \"runId\":\"@{pipeline().runId}\",\n    \"completedAt\":\"@{utCnow()}\",\n    \"message\":\"shopy Easy pipeline completed Successfully\"\n}",
						"type": "Expression"
					},
					"timeout": "00:10:00"
				}
			}
		],
		"parameters": {
			"Mater": {
				"type": "string",
				"defaultValue": "Full"
			}
		},
		"annotations": []
	}
}