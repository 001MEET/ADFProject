{
	"name": "DF_Enrichorders",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_FactOrders",
						"type": "DatasetReference"
					},
					"name": "factOrders"
				},
				{
					"dataset": {
						"referenceName": "DS_Blob_Customer",
						"type": "DatasetReference"
					},
					"name": "Customer"
				},
				{
					"dataset": {
						"referenceName": "DS_Blob_Product",
						"type": "DatasetReference"
					},
					"name": "Products"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_FactOrders",
						"type": "DatasetReference"
					},
					"name": "LoadEnrichorders"
				}
			],
			"transformations": [
				{
					"name": "OrderwithCustomer"
				},
				{
					"name": "Productwithproductname"
				},
				{
					"name": "WithProfit"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderId as string,",
				"          CustomerId as string,",
				"          ProductId as string,",
				"          CustomerName as string,",
				"          ProductName as string,",
				"          Category as string,",
				"          OrderDate as date,",
				"          OrderMonth as integer,",
				"          OrderYear as integer,",
				"          Quantity as integer,",
				"          UnitPrice as decimal(10,2),",
				"          DiscountPct as decimal(5,2),",
				"          DiscountAmount as decimal(10,2),",
				"          GrossRevenue as decimal(10,2),",
				"          ShippingCost as decimal(10,2),",
				"          NetRevenue as decimal(10,2),",
				"          CostOfGoods as decimal(10,2),",
				"          GrossProfit as decimal(10,2),",
				"          PaymentMethod as string,",
				"          OrderStatus as string,",
				"          IsDelivered as boolean,",
				"          Region as string,",
				"          LoadedAt as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> factOrders",
				"source(output(",
				"          CustomerId as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          State as string,",
				"          Country as string,",
				"          CustomerSegment as string,",
				"          JoinDate as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Customer",
				"source(output(",
				"          ProductId as string,",
				"          ProductName as string,",
				"          Category as string,",
				"          SubCategory as string,",
				"          Brand as string,",
				"          UnitPrice as integer,",
				"          CostPrice as integer,",
				"          StockQty as string,",
				"          Supplier as string,",
				"          IsActive as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Products",
				"factOrders, Customer join(factOrders@CustomerId == Customer@CustomerId,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> OrderwithCustomer",
				"OrderwithCustomer, Products join(factOrders@ProductId == Products@ProductId,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> Productwithproductname",
				"Productwithproductname derive(CostofGoods = CostPrice*Quantity,",
				"          Grossprofit = NetRevenue-(Quantity*CostPrice),",
				"          ProfitMarginPct = (NetRevenue-Quantity*CostPrice)/100) ~> WithProfit",
				"WithProfit select(mapColumn(",
				"          OrderId,",
				"          CustomerId = factOrders@CustomerId,",
				"          ProductId = factOrders@ProductId,",
				"          CustomerName,",
				"          ProductName = factOrders@ProductName,",
				"          Category = factOrders@Category,",
				"          OrderDate,",
				"          OrderMonth,",
				"          OrderYear,",
				"          Quantity,",
				"          UnitPrice = factOrders@UnitPrice,",
				"          DiscountPct,",
				"          DiscountAmount,",
				"          GrossRevenue,",
				"          ShippingCost,",
				"          NetRevenue,",
				"          CostOfGoods = factOrders@CostOfGoods,",
				"          GrossProfit = factOrders@GrossProfit,",
				"          PaymentMethod,",
				"          OrderStatus,",
				"          IsDelivered,",
				"          Region,",
				"          LoadedAt,",
				"          CustomerId = Customer@CustomerId,",
				"          FirstName,",
				"          LastName,",
				"          Email,",
				"          Phone,",
				"          City,",
				"          State,",
				"          Country,",
				"          CustomerSegment,",
				"          JoinDate,",
				"          ProductId = Products@ProductId,",
				"          ProductName = Products@ProductName,",
				"          Category = Products@Category,",
				"          SubCategory,",
				"          Brand,",
				"          UnitPrice = Products@UnitPrice,",
				"          CostPrice,",
				"          StockQty,",
				"          Supplier,",
				"          IsActive,",
				"          CostofGoods = WithProfit@CostofGoods,",
				"          Grossprofit = WithProfit@Grossprofit,",
				"          ProfitMarginPct",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          OrderId as string,",
				"          CustomerId as string,",
				"          ProductId as string,",
				"          CustomerName as string,",
				"          ProductName as string,",
				"          Category as string,",
				"          OrderDate as date,",
				"          OrderMonth as integer,",
				"          OrderYear as integer,",
				"          Quantity as integer,",
				"          UnitPrice as decimal(10,2),",
				"          DiscountPct as decimal(5,2),",
				"          DiscountAmount as decimal(10,2),",
				"          GrossRevenue as decimal(10,2),",
				"          ShippingCost as decimal(10,2),",
				"          NetRevenue as decimal(10,2),",
				"          CostOfGoods as decimal(10,2),",
				"          GrossProfit as decimal(10,2),",
				"          PaymentMethod as string,",
				"          OrderStatus as string,",
				"          IsDelivered as boolean,",
				"          Region as string,",
				"          LoadedAt as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          OrderId,",
				"          CustomerId,",
				"          ProductId,",
				"          CustomerName,",
				"          ProductName,",
				"          Category,",
				"          OrderDate,",
				"          OrderMonth,",
				"          OrderYear,",
				"          Quantity,",
				"          UnitPrice,",
				"          DiscountPct,",
				"          DiscountAmount,",
				"          GrossRevenue,",
				"          ShippingCost,",
				"          NetRevenue,",
				"          CostOfGoods = select1@CostofGoods,",
				"          GrossProfit = select1@GrossProfit,",
				"          PaymentMethod,",
				"          OrderStatus,",
				"          IsDelivered,",
				"          Region,",
				"          LoadedAt",
				"     )) ~> LoadEnrichorders"
			]
		}
	}
}